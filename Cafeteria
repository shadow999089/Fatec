from abc import ABC, abstractmethod

# Componente Concreto
class Bebida(ABC):
    @abstractmethod
    def custo(self):
         pass
    
    @abstractmethod
    def descricao(self):
        pass


# Componente Concreto
class CafeSimples(Bebida):
    def custo(self):
         return 5.0  

    def descricao(self):
        return"Café Simples"


# Decorator Concretos
class DecoratorBebida(Bebida):
    def__init__(self,bebida):
        self._bebida=bebida


# Decoradores Concreto
class Leite(DecoratorBebida):
    def custo(self):
        return self._bebida.custo() + 2.0

        def descricao(self):
        return self._bebida() + ", Leite"


class Chocolate(DecoratorBebida):
    def custo(self):
        return self._bebida.custo() + 3.0

    def descricao(self):
        return self._bebida.descricao() + ", Chocolate"


# Utilizacão
bebida = CafeSimples()
bebida = Leite(bebida)
bebida = Chocolate(bebida)

print("Descrição:",bebida.descricao())
print("Custo: R$",bebida.custo())
